/*
========================================================================================
    16S PROFILING PIPELINE - Configuration File
========================================================================================
*/

/*
========================================================================================
    Cache Directories
========================================================================================
    These directories will store downloaded databases and container images.
    Set them to persistent, shared locations to avoid re-downloading.
    
    Recommended setup:
    - Use shared filesystem paths accessible to all compute nodes
    - Ensure sufficient storage (Classifiers ~ 500MB, containers ~4GB)
========================================================================================
*/

params {
    
    ////////////////////////////////////////////////////////////////////////////////////
    // Cache directories
    singularity_cache_dir     = './singularity_cache'  // Container images cache
    classifiers_dir = './classifiers' // path to your classifiers
    bowtie_dir = './bowtie_phix' // path to your bowtie indexes
    hostile_index_dir = './hostile_index' // path to pre-downloaded hostile human index
    blast_db_dir = './blast_db' // path to local BLAST databases (16S_ribosomal_RNA)

    ////////////////////////////////////////////////////////////////////////////////////
    // Input/Output options
    input                      = null
    outdir                     = './results'
    
    ////////////////////////////////////////////////////////////////////////////////////
    // Run parameters
    tax_level = "asv"
    run_id = "run01"
    all = true
    quick       = false
    quick_depth = 1000
    metastandard_top_n = 10

    ////////////////////////////////////////////////////////////////////////////////////
    // FastQC parameters
    fastqc_extra_args                 = ''

    ////////////////////////////////////////////////////////////////////////////////////
    // Cutadapt parameters
    f_primer = "CCTACGGGNGGCWGCAG"
    r_primer = "GACTACHVGGGTATCTAATCC"
    f_nextera = "TCGTCGGCAGCGTCAGATGTGTATAAGAGACAG"
    r_nextera = "GTCTCGTGGGCTCGGAGATGTGTATAAGAGACAG"

    ////////////////////////////////////////////////////////////////////////////////////
    // DADA2 parameters

    // paired-end mode
    paired_truncQ = 2 
    truncLen_R1 = 230
    truncLen_R2 = 230
    maxEE_R1 = 2
    maxEE_R2 = 5
    maxMismatch = 1
    minOverlap = 10

    // single-end mode
    single_truncQ = 2
    truncLen = 400
    maxEE = 2

    ////////////////////////////////////////////////////////////////////////////////////
    // bbmap parameters
    bbmap_trimq = 15
    bbmap_maxlength = 600
    bbmap_mininsert = 50

    ////////////////////////////////////////////////////////////////////////////////////
    // UNOISE3 (vsearch) parameters
    unoise_maxee = 1.0       // Max expected errors for quality filtering
    unoise_minlen = 100      // Min sequence length after filtering
    unoise_minsize = 2       // Min abundance to keep a unique sequence
    unoise_alpha = 2.0       // UNOISE alpha parameter
    unoise_id = 0.97         // Identity threshold for mapping reads to ZOTUs
    unoise_fastq_qmax = 93   // Max FASTQ quality score (modern Illumina can exceed default 41)

    ////////////////////////////////////////////////////////////////////////////////////
    // DEBLUR parameters
    deblur_ptrimlength = 400
    deblur_minreads = 10
    deblur_minsize = 2

    ////////////////////////////////////////////////////////////////////////////////////
    // QIIME NAIVE BAYES
    qiime_naive_bayes_confidence = 0.7

    ////////////////////////////////////////////////////////////////////////////////////
    // QIIME BLAST
    blast_percidentity = 0.8
    blast_minconsensus = 0.51

    ////////////////////////////////////////////////////////////////////////////////////
    // Mock community evaluation parameters
    mock_evaluation                   = true  // Enable/disable mock evaluation
    mock_pattern                      = 'Mock\\d+'  // Regex to identify mock samples
    mock_abundance                    = './composition/mock_asv_abundance.csv'  // Reference abundances
    mock_taxa                         = './composition/mock_taxa.csv'  // Reference taxonomy
    mock_top_n                        = 15  // Number of top genera to display in barplot
    mock_synonyms                     = "${projectDir}/composition/genus_synonyms.csv"  // Genus synonym dictionary for mock evaluation

    ////////////////////////////////////////////////////////////////////////////////////
    // Custom summary report parameters
    custom_summary                    = true   // Enable/disable custom per-run summary
    custom_summary_blast              = false   // Run BLAST on overrepresented sequences using local 16S_ribosomal_RNA db (best-effort, skipped on failure)
    custom_summary_blast_timeout      = 240    // Seconds to wait for blastn per sequence before giving up
    custom_summary_top_overreps       = 10      // Top N overrepresented sequences to include in report and BLAST (most abundant first)
    custom_summary_blast_db           = '16S_ribosomal_RNA'  // BLAST database name (shown in report and passed to blastn)
    min_reads_threshold               = 10000  // Samples below this raw read count are flagged in the summary

    ////////////////////////////////////////////////////////////////////////////////////
    // MultiQC parameters
    multiqc_config                    = null
    multiqc_title                     = '16S Profiling Report'
    multiqc_extra_args                = ''
    
    ////////////////////////////////////////////////////////////////////////////////////
    // Resource allocation defaults (can be overridden per process)
    max_cpus                          = 16
    max_memory                        = '128.GB'
    max_time                          = '48.h'
}

/*
========================================================================================
    Singularity configuration
========================================================================================
*/

singularity {
    enabled = true
    autoMounts = true
    cacheDir = params.singularity_cache_dir
    envWhitelist = 'SINGULARITY_TMPDIR'
    pullTimeout = '2h'
    runOptions = "--bind ${params.classifiers_dir}"
}

process {
    
    // Global container settings
    container = null
    
    // Error strategy
    errorStrategy = 'terminate'
    
    // FastQC raw
    withName: 'FASTQC_RAW' {
        cpus = 4
        memory = 8.GB
        time = 2.h
        container = 'docker://quay.io/biocontainers/fastqc:0.12.1--hdfd78af_0'
    }

    withName: 'FASTQC_TRIMMED' {
        cpus = 4
        memory = 8.GB
        time = 2.h
        container = 'docker://quay.io/biocontainers/fastqc:0.12.1--hdfd78af_0'
    }

    withName: 'CUTADAPT' {
        cpus = 4
        memory = 8.GB
        time = 2.h
        container = 'docker://quay.io/biocontainers/cutadapt:5.2--py311haab0aaa_0'
    }

    withName: 'CUTADAPT_DADA2_ORIENT' {
        cpus = 4
        memory = 8.GB
        time = 2.h
        container = 'docker://quay.io/biocontainers/cutadapt:5.2--py311haab0aaa_0'
    }

    withName: 'HOST_REMOVAL'{
        cpus = 4
        memory = 8.GB
        time = 2.h
        container = 'docker://quay.io/biocontainers/bowtie2:2.5.5--ha27dd3b_0'
    }

    withName: 'PHIX_REMOVAL'{
        cpus = 4
        memory = 8.GB
        time = 2.h
        container = 'docker://quay.io/biocontainers/bowtie2:2.5.5--ha27dd3b_0'
    }
    
    withName: 'DADA2_PAIRED' {
        cpus = 16
        memory = 8.GB
        time = 2.h
        container = 'docker://quay.io/biocontainers/bioconductor-dada2:1.38.0--r45ha27e39d_0'
    }

    withName: 'DADA2_SINGLE' {
        cpus = 16
        memory = 8.GB
        time = 2.h
        container = 'docker://quay.io/biocontainers/bioconductor-dada2:1.38.0--r45ha27e39d_0'
    }


    withName: 'MERGING_READS'{
        cpus = 4
        memory = 8.GB
        time = 2.h
        container = 'docker://quay.io/biocontainers/bbmap:39.52--he5f24ec_0'
    }

    withName: 'ORIENTING_READS'{
        cpus = 4
        memory = 4.GB
        time = 2.h
        container = 'docker://quay.io/biocontainers/vsearch:2.30.5--h0bb26bb_0'
    }

    withName: 'VSEARCH_UNOISE3'{
        cpus = 16
        memory = 8.GB
        time = 2.h
        container = 'docker://quay.io/biocontainers/vsearch:2.30.5--h0bb26bb_0'
    }

    withName: 'QIIME_IMPORT'{
        cpus = 16
        memory = 8.GB
        time = 2.h
        container = 'docker://quay.io/qiime2/amplicon:2026.1'
    } 
    
    withName: 'QIIME_DEBLUR'{
        cpus = 16
        memory = 8.GB
        time = 2.h
        container = 'docker://quay.io/qiime2/amplicon:2026.1'
    }

    withName: 'QIIME_NAIVE_BAYES'{
        cpus = 16
        memory = 8.GB
        time = 2.h
        container = 'docker://quay.io/qiime2/amplicon:2026.1'
    }

    withName: 'QIIME_BLAST'{
        cpus = 16
        memory = 8.GB
        time = 2.h
        container = 'docker://quay.io/qiime2/amplicon:2026.1'
    }

    withName: 'IDTAXA'{
        cpus = 16
        memory = 8.GB
        time = 2.h
        container = 'quay.io/biocontainers/bioconductor-decipher:3.6.0--r45h01b2380_0'
    }

    withName: 'ASSIGNTAXONOMY' {
        cpus = 4
        memory = 8.GB
        time = 2.h
        container = 'docker://quay.io/biocontainers/bioconductor-dada2:1.38.0--r45ha27e39d_0'
    }

    // METASTANDARD
    withName: 'METASTANDARD' {
        cpus = 4
        memory = 8.GB
        time = 4.h
        container = 'docker://quay.io/biocontainers/pandas:2.2.1'
    }

    // MOCK EVALUATION
    // Uses the seaborn biocontainer because seaborn pulls in
    // pandas + numpy + scipy + matplotlib as runtime dependencies,
    // covering everything bin/mock_evaluation.py imports.
    withName: 'MOCK_EVALUATION' {
        cpus = 2
        memory = 4.GB
        time = 1.h
        container = 'docker://quay.io/biocontainers/seaborn:0.13.2'
    }

    // Custom summary report — three processes because no single
    // biocontainer ships both Python and BLAST+. Parse/render run in
    // the pandas image (already used elsewhere in the pipeline) and
    // BLAST runs in the BLAST+ biocontainer.
    withName: 'CUSTOM_SUMMARY_PARSE' {
        cpus = 2
        memory = 2.GB
        time = 30.min
        container = 'docker://quay.io/biocontainers/pandas:2.2.1'
    }

    withName: 'CUSTOM_SUMMARY_BLAST' {
        cpus = 2
        memory = 2.GB
        time = 2.h
        container = 'docker://quay.io/biocontainers/blast:2.16.0--h66d330f_4'
        // Best-effort step: never abort the pipeline if remote BLAST
        // fails. The process script captures errors into a sentinel
        // file, but we add a belt-and-braces ignore here too.
        errorStrategy = 'ignore'
    }

    withName: 'CUSTOM_SUMMARY_RENDER' {
        cpus = 2
        memory = 2.GB
        time = 30.min
        container = 'docker://quay.io/biocontainers/pandas:2.2.1'
    }

     // MultiQC
    withName: 'MULTIQC' {
        cpus = 2
        memory = 4.GB
        time = 1.h
        container = 'docker://quay.io/biocontainers/multiqc:1.21--pyhdfd78af_0'
    }

    // MetaStandard plots
    withName: 'METASTANDARD_PLOTS' {
        cpus = 2
        memory = 4.GB
        time = 1.h
        container = 'docker://quay.io/biocontainers/seaborn:0.13.2'
    }

    // Subsampling (--quick mode)
    withName: 'SEQTK_SUBSAMPLE' {
        cpus = 2
        memory = 4.GB
        time = 1.h
        container = 'docker://quay.io/biocontainers/seqtk:1.4--he4a0461_2'
    }


}

/*
========================================================================================
    Report and trace options
========================================================================================
*/

timeline {
    enabled = true
    overwrite = true
    file = "${params.outdir}/pipeline_info/timeline.html"
}

report {
    enabled = true
    overwrite = true
    file = "${params.outdir}/pipeline_info/report.html"
}

trace {
    enabled = true
    overwrite = true
    file = "${params.outdir}/pipeline_info/trace.txt"
}

dag {
    enabled = true
    overwrite = true
    file = "${params.outdir}/pipeline_info/dag.svg"
}

manifest {
    name = 'metagenomic-profiling-pipeline'
    author = 'Petra Polakovicova & Alise Ponsero'
    description = 'Nextflow pipeline for 16S profiling benchmark with cutadapt, dada2, deblur, usearch, and different taxonomic classifiers.'
    mainScript = 'main.nf'
    nextflowVersion = '>=22.10.0'
    version = '1.0.0'
}
